# ── Serveur ────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Base de données ────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/skillswap

# ── JWT ────────────────────────────────────────────────────────
JWT_SECRET=change_me_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# ── Frontend (CORS) ────────────────────────────────────────────
# Séparer plusieurs origines par une virgule
CLIENT_URL=http://localhost:5173,http://localhost:5174

# ── Emails (optionnel — la création de compte fonctionne sans) ─
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
